# ==========================================================================
# CloudVault Backend - Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ==========================================================================

# --- App ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
# Either provide DATABASE_URL directly (e.g. for hosted Postgres like Render/Supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cloudvault
# ...or use the individual fields below (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloudvault
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# --- Auth (JWT) ---
# Generate strong secrets with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_SALT_ROUNDS=12

# --- File Encryption (AES-256) ---
# Must be a 32-byte value, e.g. generate with: openssl rand -hex 32
FILE_ENCRYPTION_KEY=replace_with_32_byte_hex_key

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Email (Nodemailer / SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM="CloudVault <no-reply@cloudvault.dev>"

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
